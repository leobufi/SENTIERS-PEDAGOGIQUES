<div class="page-main">
  <div class="page-padding no-padding">
    <section class="dynamic-pages" data-controller="swiper">
      <div class="dynamic-pages_wrapper">
        <div class="point-tabs_wrapper">
          <span class="point-tab active" data-tabs-target="tab" data-action="click->tabs#activate" data-tab-name="infos">Généralités</span>
          <span class="point-tab" data-tabs-target="tab" data-action="click->tabs#activate" data-tab-name="images">Détails</span>
          <span class="point-tab" data-tabs-target="tab" data-action="click->tabs#activate" data-tab-name="video">Vidéo</span>
          <span class="point-tab no-border" data-tabs-target="tab" data-action="click->tabs#activate" data-tab-name="ressources">Ressources</span>
        </div>
        <div class="point-content_wrapper infos active" data-tabs-target="panel" data-tab-name="infos">
          <div class="point-image">
            <% if @point.image_1.attached? %>
              <%= cl_image_tag @point.image_1.key, crop: :fit %>
            <% end %>
          </div>
          <div class="point-content">
            <% if @point.title.empty? && @point.infos.empty? %>
              <p class="mobile-margin">Il n'y a pas d'informations pour ce point d'interêt.</p>
            <% else %>
              <h2><%= @point.title %></h2>
              <p><%= @point.infos %></p>
            <% end %>
          </div>
        </div>
        <div class="point-content_wrapper images" data-tabs-target="panel" data-tab-name="images">
          <%= render "swiper" %>
        </div>
        <div class="point-content_wrapper video" data-tabs-target="panel" data-tab-name="video">
          <div class="point-content">
            <% if @point.video.empty? %>
              <p class="mobile-margin">Il n'y a pas de contenu vidéo pour ce point d'interêt.</p>
            <% else %>
              <iframe width="100%" height="550" src="https://player.vimeo.com/video/<%=@point.video%>" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen=""></iframe>
            <% end %>
          </div>
        </div>
        <div class="point-content_wrapper ressources" data-tabs-target="panel" data-tab-name="ressources">
          <div class="point-content">
            <h2 class="mobile-margin">Bibliographie, liens et informations complémentaires</h2>
            <% if @point.bibliography.empty? %>
              <p>Il n'y a pas d'informations complémentaires pour ce point d'interêt.</p>
            <% else %>
              <%=  @point.bibliography %>
            <% end %>
            <h2>Audio</h2>
            <% if @point.audio.empty? %>
              <p >Il n'y a pas de contenu audio pour ce point d'interêt.</p>
            <% else %>
              <%=  @point.audio.html_safe %>
            <% end %>
            <h2>PDF</h2>
            <% if @point.pdf.attached? %>
             <%= link_to "Télécharger le PDF pour #{@point.title}", rails_blob_path(@point.pdf, disposition: "attachment"), target: "_blank" %>
              <% else %>
              <p>Il n'y a pas de pdf à télécharger pour ce point d'interêt.</p>
            <% end %>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>
